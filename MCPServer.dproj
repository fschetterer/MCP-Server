<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
    <PropertyGroup>
        <ProjectGuid>{B8E3F4A1-9C2D-4E5F-8A1B-7C3D9E0F2A4B}</ProjectGuid>
        <ProjectVersion>20.3</ProjectVersion>
        <FrameworkType>None</FrameworkType>
        <MainSource>MCPServer.dpr</MainSource>
        <Base>True</Base>
        <Config Condition="'$(Config)'==''">Release</Config>
        <Platform Condition="'$(Platform)'==''">Win64</Platform>
        <TargetedPlatforms>3</TargetedPlatforms>
        <AppType>Console</AppType>
        <ProjectName Condition="'$(ProjectName)'==''">MCPServer</ProjectName>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Base' or '$(Base)'!=''">
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Debug' or '$(Cfg_1)'!=''">
        <Cfg_1>true</Cfg_1>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="('$(Platform)'=='Win64' and '$(Cfg_1)'=='true') or '$(Cfg_1_Win64)'!=''">
        <Cfg_1_Win64>true</Cfg_1_Win64>
        <CfgParent>Cfg_1</CfgParent>
        <Cfg_1>true</Cfg_1>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='NoCodeSite' or '$(Cfg_3)'!=''">
        <Cfg_3>true</Cfg_3>
        <CfgParent>Cfg_1</CfgParent>
        <Cfg_1>true</Cfg_1>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="('$(Platform)'=='Win64' and '$(Cfg_3)'=='true') or '$(Cfg_3_Win64)'!=''">
        <Cfg_3_Win64>true</Cfg_3_Win64>
        <CfgParent>Cfg_3</CfgParent>
        <Cfg_3>true</Cfg_3>
        <Cfg_1>true</Cfg_1>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Release' or '$(Cfg_2)'!=''">
        <Cfg_2>true</Cfg_2>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='_NoCodeSite' or '$(Cfg_4)'!=''">
        <Cfg_4>true</Cfg_4>
        <CfgParent>Cfg_2</CfgParent>
        <Cfg_2>true</Cfg_2>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="('$(Platform)'=='Win64' and '$(Cfg_4)'=='true') or '$(Cfg_4_Win64)'!=''">
        <Cfg_4_Win64>true</Cfg_4_Win64>
        <CfgParent>Cfg_4</CfgParent>
        <Cfg_4>true</Cfg_4>
        <Cfg_2>true</Cfg_2>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Base)'!=''">
        <SanitizedProjectName>MCPServer</SanitizedProjectName>
        <DCC_UnitSearchPath>$(mormot2);$(mormot2)\core;$(mormot2)\lib;$(mormot2)\crypt;$(mormot2)\net;$(mormot2)\db;$(mormot2)\rest;$(mormot2)\orm;$(mormot2)\soa;$(mormot2)\app;$(mormot2)\script;$(mormot2)\ui;$(mormot2)\tools;$(mormot2)\misc;$(DCC_UnitSearchPath)</DCC_UnitSearchPath>
        <VerInfo_Locale>1033</VerInfo_Locale>
        <DCC_Namespace>Vcl;Vcl.Imaging;Vcl.Touch;Vcl.Samples;Vcl.Shell;System;Winapi;System.Win;Xml;Data;Data.Win;Datasnap.Win;Web.Win;Soap.Win;Xml.Win;$(DCC_Namespace)</DCC_Namespace>
        <DCC_IMPLICIT_STRING_CAST>false</DCC_IMPLICIT_STRING_CAST>
        <DCC_Define>CODESITE;$(DCC_Define)</DCC_Define>
        <DCC_ExeOutput>.</DCC_ExeOutput>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Cfg_1)'!=''">
        <DCC_Optimize>false</DCC_Optimize>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Cfg_1_Win64)'!=''">
        <Manifest_File>(None)</Manifest_File>
        <AppDPIAwarenessMode>none</AppDPIAwarenessMode>
        <DCC_IMPLICIT_STRING_CAST>false</DCC_IMPLICIT_STRING_CAST>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Cfg_3)'!=''"/>
    <PropertyGroup Condition="'$(Cfg_3_Win64)'!=''"/>
    <PropertyGroup Condition="'$(Cfg_4)'!=''"/>
    <PropertyGroup Condition="'$(Cfg_4_Win64)'!=''">
        <Manifest_File>(None)</Manifest_File>
        <AppDPIAwarenessMode>none</AppDPIAwarenessMode>
    </PropertyGroup>
    <ItemGroup>
        <DelphiCompile Include="$(MainSource)">
            <MainSource>MainSource</MainSource>
        </DelphiCompile>
        <DCCReference Include="src\Protocol\MCP.Types.pas"/>
        <DCCReference Include="src\Server\MCP.Server.pas"/>
        <DCCReference Include="src\Core\MCP.Manager.Registry.pas"/>
        <DCCReference Include="src\Core\MCP.Events.pas"/>
        <DCCReference Include="src\Managers\MCP.Manager.Core.pas"/>
        <DCCReference Include="src\Managers\MCP.Manager.Logging.pas"/>
        <DCCReference Include="src\Managers\MCP.Manager.Tools.pas"/>
        <DCCReference Include="src\Tools\MCP.Tool.Base.pas"/>
        <DCCReference Include="src\Tools\MCP.Tool.Echo.pas"/>
        <DCCReference Include="src\Tools\MCP.Tool.GetTime.pas"/>
        <DCCReference Include="src\Tools\MCP.Tool.BuildService.pas"/>
        <DCCReference Include="src\Tools\MCP.Tool.DelphiBuild.pas"/>
        <DCCReference Include="src\Tools\MCP.Tool.DelphiLookup.pas"/>
        <DCCReference Include="src\Tools\MCP.Tool.DelphiIndexer.pas"/>
        <DCCReference Include="src\Tools\MCP.Tool.WindowsExec.pas"/>
        <DCCReference Include="src\Tools\MCP.Tool.WindowsDir.pas"/>
        <DCCReference Include="src\Tools\MCP.Tool.WindowsExists.pas"/>
        <DCCReference Include="src\Tools\MCP.Tool.LSPClient.pas"/>
        <DCCReference Include="src\Tools\MCP.Tool.DelphiHover.pas"/>
        <DCCReference Include="src\Tools\MCP.Tool.DelphiDefinition.pas"/>
        <DCCReference Include="src\Tools\MCP.Tool.DelphiReferences.pas"/>
        <DCCReference Include="src\Tools\MCP.Tool.DelphiDocSymbols.pas"/>
        <DCCReference Include="src\Resources\MCP.Resource.Base.pas"/>
        <DCCReference Include="src\Managers\MCP.Manager.Resources.pas"/>
        <DCCReference Include="src\Prompts\MCP.Prompt.Base.pas"/>
        <DCCReference Include="src\Managers\MCP.Manager.Prompts.pas"/>
        <DCCReference Include="src\Managers\MCP.Manager.Completion.pas"/>
        <DCCReference Include="src\Transport\MCP.Transport.Base.pas"/>
        <DCCReference Include="src\Transport\MCP.Transport.Http.pas"/>
        <BuildConfiguration Include="Base">
            <Key>Base</Key>
        </BuildConfiguration>
        <BuildConfiguration Include="Release">
            <Key>Cfg_2</Key>
            <CfgParent>Base</CfgParent>
        </BuildConfiguration>
        <BuildConfiguration Include="NoCodeSite">
            <Key>Cfg_4</Key>
            <CfgParent>Cfg_2</CfgParent>
        </BuildConfiguration>
        <BuildConfiguration Include="Debug">
            <Key>Cfg_1</Key>
            <CfgParent>Base</CfgParent>
        </BuildConfiguration>
        <BuildConfiguration Include="NoCodeSite">
            <Key>Cfg_3</Key>
            <CfgParent>Cfg_1</CfgParent>
        </BuildConfiguration>
    </ItemGroup>
    <ProjectExtensions>
        <Borland.Personality>Delphi.Personality.12</Borland.Personality>
        <Borland.ProjectType/>
        <BorlandProject>
            <Delphi.Personality>
                <Source>
                    <Source Name="MainSource">MCPServer.dpr</Source>
                </Source>
                <Excluded_Packages>
                    <Excluded_Packages Name="$(BDSBIN)\dcloffice2k290.bpl">Microsoft Office 2000 Sample Automation Server Wrapper Components</Excluded_Packages>
                    <Excluded_Packages Name="$(BDSBIN)\dclofficexp290.bpl">Microsoft Office XP Sample Automation Server Wrapper Components</Excluded_Packages>
                </Excluded_Packages>
            </Delphi.Personality>
            <Platforms>
                <Platform value="Win32">True</Platform>
                <Platform value="Win64">True</Platform>
            </Platforms>
        </BorlandProject>
        <ProjectFileVersion>12</ProjectFileVersion>
    </ProjectExtensions>
    <Import Project="$(BDS)\Bin\CodeGear.Delphi.Targets" Condition="Exists('$(BDS)\Bin\CodeGear.Delphi.Targets')"/>
    <Import Project="$(APPDATA)\Embarcadero\$(BDSAPPDATABASEDIR)\$(PRODUCTVERSION)\UserTools.proj" Condition="Exists('$(APPDATA)\Embarcadero\$(BDSAPPDATABASEDIR)\$(PRODUCTVERSION)\UserTools.proj')"/>
    <Import Project="$(MSBuildProjectName).deployproj" Condition="Exists('$(MSBuildProjectName).deployproj')"/>
</Project>
